{
  "name": "@basecrawl/sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for the basecrawl ScrapeProof crawler",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "basecrawl_sdk.node"
  ],
  "scripts": {
    "build": "cargo build --manifest-path Cargo.toml --release && cp ../../target/release/libbasecrawl_sdk.so basecrawl_sdk.node",
    "lint": "node --check index.js && node --check tests/*.test.js",
    "prepack": "pnpm run build",
    "pretest": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
